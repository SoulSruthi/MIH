{
  "name": "vibe-coding-os",
  "version": "5.0.0-rc.0",
  "description": "Vibe Coding OS V5 — native + minimal. Bash-first orchestration, Plan Mode review, auto-revert watchdog. Internal-only Builtrix product line OS.",
  "type": "module",
  "bin": {
    "vibe-os": "plugin/bin/init.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:playwright": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:e2e": "playwright test --grep @e2e",
    "test:hooks": "node --test tests/hooks/*.test.mjs",
    "test:skills": "node --test tests/skills/*.test.mjs",
    "test:agents": "node --test tests/agents/*.test.mjs",
    "test:plugin": "node --test tests/plugin/*.test.mjs",
    "test:mcp": "node --test tests/mcp/*.test.mjs",
    "test:v4": "node --test tests/hooks/*.test.mjs tests/skills/*.test.mjs tests/agents/*.test.mjs tests/plugin/*.test.mjs tests/mcp/*.test.mjs",
    "vibe:init": "node plugin/bin/init.mjs",
    "prepare": "node -e \"if(process.env.CI!=='true'&&!process.env.VERCEL)require('husky')()\"",
    "test:security": "npx ts-node --esm scripts/secret-scanner.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.1",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "inngest": "^4.4.0",
    "lucide-react": "^0.563.0",
    "next": "^16.1.5",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "shadcn": "^3.7.0",
    "supabase": "^2.74.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.3.0",
    "vercel": "^50.5.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
